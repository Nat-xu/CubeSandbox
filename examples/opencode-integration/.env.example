# --- CubeSandbox connection ---

# Required: CubeAPI address (use CubeAPI, not CubeProxy).
E2B_API_URL="http://<your-cube-api>:8080"

# Required: any non-empty value in local dev; a real key when auth is enabled.
E2B_API_KEY="<your-api-key>"

# Required: template built from this example's Dockerfile.
CUBE_TEMPLATE_ID="<template-id-from-cubemastercli>"

# --- LLM Provider (OpenCode supports multiple providers) ---

# Required: the provider API key passed to the sandbox command.
OPENAI_API_KEY="<your-openai-key>"
# Or for other providers uncomment the one you use:
# ANTHROPIC_API_KEY="<your-anthropic-key>"

# Optional: override the default provider set in the Dockerfile's opencode.json.
# OPENCODE_PROVIDER="openai"

# Optional: self-signed cert for CubeAPI when connecting over HTTPS.
# SSL_CERT_FILE="/path/to/ca-cert.pem"
